{
  "name": "skillgap-root",
  "private": true,
  "version": "1.0.0",
  "scripts": {
    "dev:client": "npm --prefix client run dev",
    "dev:server": "python3 -m uvicorn main:app --app-dir server --reload --port 8000",
    "dev": "concurrently -n \"frontend,backend\" -c \"blue,green\" \"npm run dev:client\" \"npm run dev:server\"",
    "install:client": "npm install --prefix client",
    "install:server": "python3 -m pip install -r server/requirements.txt",
    "install:all": "npm install && npm run install:client && npm run install:server"
  },
  "engines": {
    "node": ">=22"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}