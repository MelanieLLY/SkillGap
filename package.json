{
  "name": "skillgap-root",
  "private": true,
  "version": "1.0.0",
  "workspaces": [
    "client"
  ],
  "scripts": {
    "dev:client": "npm run dev --workspace=client",
    "dev:server": "python -m uvicorn server.main:app --reload --port 8000",
    "dev": "concurrently -n \"frontend,backend\" -c \"blue,green\" \"npm run dev:client\" \"npm run dev:server\"",
    "install:client": "npm install --workspace=client",
    "install:server": "python -m pip install -r server/requirements.txt",
    "install:all": "npm install && npm run install:client && npm run install:server"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}