{
    "name": "skillgap",
    "version": "1.0.0",
    "private": true,
    "scripts": {
        "dev:frontend": "cd frontend && npm run dev",
        "dev:backend": "cd backend && ../venv/bin/uvicorn main:app --reload --port 8000",
        "dev": "concurrently \"npm run dev:frontend\" \"npm run dev:backend\"",
        "install:all": "npm install && cd frontend && npm install && cd .. && python3 -m venv venv && ./venv/bin/pip install -r backend/requirements.txt",
        "setup": "npm run install:all"
    },
    "devDependencies": {
        "concurrently": "^8.2.2"
    }
}